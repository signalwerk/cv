{
  "name": "stefan-huber-cv",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "mdast-util-from-span-markdown": "^1.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server && npm run build:ssg && cp README.md dist",
    "build:client": "tsc && vite build --outDir dist --ssrManifest",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:ssg": "tsx scripts/generate-static.ts",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "gh-pages": "^6.3.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
